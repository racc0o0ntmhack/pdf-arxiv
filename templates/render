<body>
    <div class="pdf-container">
        <!-- Brauzerin daxili PDF oxuyucusunu işə salır -->
        <iframe src="{{ url_for('static', filename='uploads/' + filename) }}#toolbar=1"></iframe>
    </div>
</body>
</html>